[mysqld]

#Archivo para configurar MySQL en Docker

# Charset y collation
character-set-server  = utf8mb4
collation-server      = utf8mb4_unicode_ci

# Motor de almacenamiento por defecto
default-storage-engine = InnoDB

# Tamaño de buffer InnoDB (ajustar según RAM disponible)
innodb_buffer_pool_size = 256M
# innodb_redo_log_capacity reemplaza a innodb_log_file_size en MySQL 8.0.30+
innodb_redo_log_capacity = 134217728
innodb_flush_log_at_trx_commit = 1

# Conexiones
max_connections = 100
wait_timeout    = 600
interactive_timeout = 600

# Caché de consultas (desactivada en MySQL 8.0+)
# query_cache_type = 0

# Zona horaria del servidor
default-time-zone = '-04:00'

# Logging lento (útil en desarrollo)
slow_query_log       = 1
slow_query_log_file  = /var/lib/mysql/slow.log
long_query_time      = 2

[client]
default-character-set = utf8mb4

[mysql]
default-character-set = utf8mb4
