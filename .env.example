APP_NAME="Veterinaria"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --------------------------
# Base de datos MySQL
# --------------------------
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=veterinaria
DB_USERNAME=vet_user
DB_PASSWORD=vet_secret
DB_ROOT_PASSWORD=root_secret

# --------------------------
# Redis
# --------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret
REDIS_DB=0
REDIS_CACHE_DB=1

# --------------------------
# Cache y Sesiones
# --------------------------
CACHE_DRIVER=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# --------------------------
# Colas (Queue)
# --------------------------
QUEUE_CONNECTION=redis

# --------------------------
# Mail (opcional)
# --------------------------
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hola@veterinaria.test"
MAIL_FROM_NAME="${APP_NAME}"

# --------------------------
# Puertos Docker (host)
# --------------------------
NGINX_PORT=8080
VITE_PORT=5173

# --------------------------
# Vite
# --------------------------
VITE_APP_NAME="${APP_NAME}"
